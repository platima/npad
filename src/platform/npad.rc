#include <windows.h>

// Embed the manifest for DPI awareness
1 24 "npad.manifest"

// Version information
1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "npad Project"
            VALUE "FileDescription", "npad - Lightweight Text Editor"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "npad"
            VALUE "LegalCopyright", "Copyright (c) 2024"
            VALUE "OriginalFilename", "npad.exe"
            VALUE "ProductName", "npad"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

// Application icon (placeholder - would need actual icon file)
// IDI_APPLICATION ICON "npad.ico"